// Master Tables for AI Import Wizard - Phase 2

// Generic (active ingredient) master table
model Generic {
  id        String   @id @default(cuid())
  name      String   @unique // Primary generic name (e.g., "Esomeprazole")
  synonyms  Json?    // Array of alternative names/spellings (e.g., ["Esomeprazol", "Esomeprazole Magnesium"])
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  drafts AiProductDraft[]

  @@index([name])
}

// Manufacturer master table
model Manufacturer {
  id                    String   @id @default(cuid())
  name                  String   @unique // Primary manufacturer name (e.g., "Square Pharmaceuticals Ltd.")
  aliasList             Json?    // Array of alternative names (e.g., ["Square", "Square Pharma"])
  slug                  String   @unique
  logoUrl               String?  // Manufacturer logo image URL
  websiteUrl            String?  // Manufacturer website URL
  description           String?  // Manufacturer description
  phoneNumber           String?  // Contact phone number (e.g., "+8801XXXXXXXXX")
  requiresQcVerification Boolean @default(true) // Whether products from this manufacturer need extra QC
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  drafts   AiProductDraft[]
  products Product[]

  @@index([name])
}

// Wishlist - user-specific product favorites
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// Discount Engine Models

model DiscountRule {
  id             String           @id @default(cuid())
  name           String           // Rule name for admin reference
  ruleType       DiscountRuleType // CATEGORY, BRAND, CART_AMOUNT, USER_GROUP
  targetValue    String?          // categoryId, manufacturerId, amount threshold, or user group
  discountType   DiscountType     // PERCENTAGE or FIXED
  discountAmount Float            // Discount value (percentage 0-100 or fixed amount)
  minCartAmount  Float?           // Minimum cart amount for CART_AMOUNT rules
  startDate      DateTime         // When the rule becomes active
  endDate        DateTime         // When the rule expires
  priority       Int              @default(0) // Higher priority rules override lower ones
  isActive       Boolean          @default(true)
  description    String?          // Optional description
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  logs DiscountLog[]

  @@index([isActive, startDate, endDate])
  @@index([ruleType])
  @@index([priority])
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique // Coupon code (e.g., "SAVE20")
  discountType   DiscountType // PERCENTAGE or FIXED
  discountAmount Float        // Discount value
  minCartAmount  Float?       // Minimum cart amount to apply coupon
  maxDiscount    Float?       // Maximum discount amount (for percentage coupons)
  usageLimit     Int?         // Total number of times coupon can be used
  usageCount     Int          @default(0) // Current usage count
  perUserLimit   Int?         // Max uses per user
  startDate      DateTime     // When the coupon becomes active
  endDate        DateTime     // When the coupon expires
  isActive       Boolean      @default(true)
  description    String?      // Optional description
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  usages CouponUsage[]

  @@index([code])
  @@index([isActive, startDate, endDate])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String   // User who used the coupon
  orderId   String?  // Order where coupon was applied
  discount  Float    // Actual discount amount applied
  usedAt    DateTime @default(now())

  @@index([couponId])
  @@index([userId])
  @@index([couponId, userId])
}

model DiscountLog {
  id             String   @id @default(cuid())
  ruleId         String?
  rule           DiscountRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  productId      String   // Product that was discounted
  oldPrice       Float    // Original price before discount
  newPrice       Float    // Price after discount
  discountAmount Float    // Amount discounted
  appliedAt      DateTime @default(now())

  @@index([ruleId])
  @@index([productId])
  @@index([appliedAt])
}

// ==========================================
// AI BLOG ENGINE MODELS
// ==========================================

model BlogTopic {
  id          String     @id @default(cuid())
  title       String     // Topic title/idea
  description String?    // Optional description of the topic
  block       TopicBlock // BEAUTY or GROCERY
  type        BlogType   // BEAUTY, GROCERY, RECIPE, MONEY_SAVING
  isActive    Boolean    @default(true)
  lastUsedAt  DateTime?  // When this topic was last used
  timesUsed   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  blogs Blog[]

  @@index([block, isActive])
  @@index([lastUsedAt])
}

model Blog {
  id          String     @id @default(cuid())
  slug        String     @unique
  type        BlogType   // BEAUTY, GROCERY, RECIPE, MONEY_SAVING
  block       TopicBlock // BEAUTY or GROCERY block
  title       String     // Human-facing title (H1)
  summary     String?    // Short intro/excerpt
  contentMd   String?    // Markdown content
  contentHtml String?    // Rendered HTML cache (optional)
  imageUrl    String?    // Featured image URL

  // SEO Fields
  seoTitle        String?  // Meta title (50-60 chars)
  seoDescription  String?  // Meta description (150-160 chars)
  seoKeywords     String?  // Comma-separated keywords
  faqJsonLd       Json?    // FAQ schema JSON-LD blob
  internalLinkSlugs String[] // Related blog slugs for internal linking

  // Topic relation
  topicId String?
  topic   BlogTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)

  // Category relation (optional, for grouping)
  primaryCategoryId String?
  primaryCategory   Category? @relation(fields: [primaryCategoryId], references: [id], onDelete: SetNull)

  // Status & Scheduling
  status      BlogStatus @default(TOPIC_ONLY)
  scheduledAt DateTime?  // When cron intends to publish
  publishedAt DateTime?  // Actual publish time
  viewCount   Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  blogProducts    BlogProduct[]
  missingProducts MissingProduct[]

  @@index([status])
  @@index([type])
  @@index([block])
  @@index([publishedAt])
  @@index([slug])
}

model BlogProduct {
  id        String  @id @default(cuid())
  blogId    String
  blog      Blog    @relation(fields: [blogId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  role      String  // "recommended", "ingredient", "alternative", "combo", "step"
  stepOrder Int?    // For skincare routines: 1=cleanser, 2=toner, etc.
  notes     String? // Optional notes about why this product is recommended

  @@unique([blogId, productId, role])
  @@index([blogId])
  @@index([productId])
}

model MissingProduct {
  id                 String   @id @default(cuid())
  name               String   // Product name that was needed
  categorySuggestion String?  // Suggested category for this product
  reason             String   // Why it's needed: "Required in recipe", "Skincare step missing", etc.
  blogId             String?  // Link to the blog that needed it
  blog               Blog?    @relation(fields: [blogId], references: [id], onDelete: SetNull)
  resolvedProductId  String?  // When admin adds the product, link it here
  isResolved         Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([isResolved])
  @@index([blogId])
}

// Market Intelligence - Phase 1 & 2
model CompetitorProduct {
  id                 String   @id @default(cuid())
  siteName           String   // 'chaldal' | 'arogga' | 'shajgoj'
  category           String   // 'rice' | 'oil' | 'paracetamol' | 'cough-syrup' | 'face-wash'
  productName        String
  price              Float
  reviewCount        Int      @default(0)
  position           Int?     // Position in listing (0 = top, higher = lower on page)
  trendScore         Float    // Phase 2: weighted score from priceScore + positionScore + reviewScore
  rawScoreComponents Json?    // { priceScore, positionScore, reviewScore, weights, minPrice, maxPrice }
  productUrl         String?  // URL to the product page
  imageUrl           String?  // Product image URL
  collectedAt        DateTime @default(now())

  @@index([siteName, category, collectedAt])
  @@index([category, trendScore])
  @@index([collectedAt])
}

// Market Intelligence - Phase 2: Sync Logs
model MarketIntelSyncLog {
  id            String    @id @default(cuid())
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        String    // 'running' | 'success' | 'error'
  siteName      String?   // Optional: specific site, null = all sites
  totalProducts Int?      // Number of products synced
  errorMessage  String?   // Error details if status = 'error'

  @@index([startedAt])
  @@index([status])
}
