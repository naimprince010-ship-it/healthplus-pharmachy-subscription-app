# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# For local development: postgresql://user:password@localhost:5432/healthplus?schema=public
# For production (Supabase/Railway): Use connection string from your provider
DATABASE_URL="postgresql://user:password@localhost:5432/healthplus?schema=public"

# Supabase/Vercel:
# Builds run `scripts/prisma-migrate-deploy.js`: if DATABASE_URL matches `postgres.[PROJECT_REF]@*.pooler.supabase.com:6543`,
# a **direct** `db.[PROJECT_REF].supabase.co:5432` URL is derived for migrations automatically (same password).
# If your pooled string/user format differs, set one of:
# DIRECT_URL → Supabase Dashboard → Connect → Postgres → URI (pick "Direct connection", host db.PROJECT.supabase.co:5432).
# Fallback names some templates use:
#DATABASE_DIRECT_URL="postgresql://..."
#POSTGRES_URL_NON_POOLING="postgresql://..."
#DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# ============================================
# NEXTAUTH CONFIGURATION
# ============================================
# Base URL for your application
# Development: http://localhost:3000
# Production: https://your-domain.com (e.g., https://halalzi.com)
NEXTAUTH_URL="http://localhost:3000"

# NextAuth secret key - MUST be changed in production
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Trust host header (NextAuth v5) - Set to true in production
# This allows NextAuth to automatically detect the host from the request
# Recommended for Vercel deployments with custom domains
AUTH_TRUST_HOST="true"

# ============================================
# SMS PROVIDER CONFIGURATION
# ============================================
# Configure your SMS provider (MIM SMS)
SMS_API_KEY="your-sms-api-key"
SMS_API_URL="https://api.sms-provider.com/send"
SMS_SENDER_ID="HealthPlus"

MIM_SMS_API_KEY="HGY5QT4ZRSDZ2XAODOZ0PXLEJ"
MIM_SMS_SENDER_ID="8809617623081"
MIM_SMS_API_URL="https://sms.mimsms.com/smsapi"
MIM_SMS_USERNAME="your-mim-sms-username"

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
EMAIL_FROM="noreply@healthplus.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# ============================================
# TRACKING & ANALYTICS
# ============================================
# Google Tag Manager (Primary tracking container)
# Get your GTM ID from https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# Google Analytics 4 Measurement ID (Optional - managed via GTM)
# Get your GA4 ID from https://analytics.google.com
NEXT_PUBLIC_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"

# Meta (Facebook/Instagram) Pixel ID (Optional - managed via GTM)
# Get your Pixel ID from https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID="000000000000000"

# TikTok Pixel ID (Optional - managed via GTM)
# Get your Pixel ID from https://ads.tiktok.com/marketing_api/docs
NEXT_PUBLIC_TIKTOK_PIXEL_ID="XXXXXXXXXXXX"

# Google Ads Conversion ID (Optional)
NEXT_PUBLIC_GOOGLE_ADS_ID="AW-XXXXXXXXX"

# ============================================
# WHATSAPP CONFIGURATION
# ============================================
# Phone number in international format without + (e.g., 8801712345678)
NEXT_PUBLIC_WHATSAPP_NUMBER="8801XXXXXXXXX"

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Maximum file size in bytes (5MB = 5242880)
NEXT_PUBLIC_MAX_FILE_SIZE="5242880"
# Directory for uploaded files (relative to project root)
UPLOAD_DIR="./public/uploads"

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Base URL for canonical tags, sitemaps, and absolute URLs
# Development: http://localhost:3000
# Production: https://your-domain.com (e.g., https://halalzi.com)
# This is used for:
# - Canonical URLs in metadata
# - Sitemap generation
# - Open Graph URLs
# - Email links
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Default admin credentials (CHANGE AFTER FIRST LOGIN)
DEFAULT_ADMIN_PHONE="+8801712345678"
DEFAULT_ADMIN_PASSWORD="ChangeMe123!"
DEFAULT_ADMIN_NAME="Admin User"
DEFAULT_ADMIN_EMAIL="admin@healthplus.com"

# ============================================
# OPENAI CONFIGURATION
# ============================================
# OpenAI API Key for AI Assistant features
# Get your API key from https://platform.openai.com/api-keys
# Used for:
# - Product content generation (descriptions, SEO, features)
# - AI chat assistant in admin dashboard
OPENAI_API_KEY="sk-your-openai-api-key-here"

# OpenAI Model to use (default: gpt-4o-mini for cost efficiency)
# Options: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# gpt-4o-mini is recommended for production (low cost, good quality)
OPENAI_MODEL="gpt-4o-mini"

# ============================================
# PAYMENT GATEWAY (Future Integration)
# ============================================
# Uncomment and configure when integrating payment gateway
# PAYMENT_GATEWAY_API_KEY="your-payment-gateway-key"
# PAYMENT_GATEWAY_SECRET="your-payment-gateway-secret"
# PAYMENT_GATEWAY_WEBHOOK_SECRET="your-webhook-secret"

# ============================================
# AZAN WHOLESALE API CONFIGURATION
# ============================================
# Docs: Live https://api.azanwholesale.com/ | Sandbox https://staging.azanwholesale.com
# GET /api/en/products/by-api?per_page=300&selected_product=0 (0=all, 1=reseller panel only)
# Other: POST /api/orders/store, GET /api/products/date/{dd-mm-yyyy}, POST /api/update-stock, POST /api/update-product
# Set these to run: npm run sync:azan
AZAN_WHOLESALE_APP_ID=""
AZAN_WHOLESALE_SECRET_KEY=""
# API hosts (see Azan docs): Live https://api.azanwholesale.com/ — Sandbox https://staging.azanwholesale.com
AZAN_WHOLESALE_BASE_URL="https://api.azanwholesale.com"
# Optional extra hosts to auto-try (comma-separated, no trailing slash)
AZAN_WHOLESALE_FALLBACK_BASE_URLS="https://staging.azanwholesale.com,https://api.azanwholesale.com,https://azanwholesale.com,https://extent.azanwholesale.com"
# Product list endpoint path (from Azan docs)
AZAN_WHOLESALE_PRODUCTS_PATH="/api/en/products/by-api?per_page=300&selected_product=0"
# Optional fixed query params from Azan docs, e.g. "select_group=1"
AZAN_WHOLESALE_EXTRA_QUERY=""
# Price formula: sellingPrice = ceil(supplierPrice * markup)
AZAN_WHOLESALE_MARKUP="1.6"
# Max pages per sync run (with per_page=300, 300 pages ≈ 90k rows — enough for full Azan catalogs; tune down if timeouts)
AZAN_WHOLESALE_MAX_PAGES="300"
# Registered store name for POST /api/orders/store (platform_source)
AZAN_WHOLESALE_PLATFORM_SOURCE="Halalzi"
# Imported products category
AZAN_WHOLESALE_CATEGORY="Azan Wholesale"
# Allow syncing catalog even when supplier price is missing in API payload
AZAN_WHOLESALE_ALLOW_MISSING_PRICE="false"
# Used only when AZAN_WHOLESALE_ALLOW_MISSING_PRICE=true
AZAN_WHOLESALE_DEFAULT_SUPPLIER_PRICE="0"
# Reseller default margin (admin sync): selling = purchase * (1 + margin/100)
# AZAN_WHOLESALE_DEFAULT_MARGIN_PERCENT="30"

# Send customer orders to Azan POST /api/orders/store (set true in production when ready; requires supplierSku on products)
AZAN_WHOLESALE_FORWARD_ORDERS="false"
# order_details[].supplier in Azan payload (docs: AzanWholeSale)
AZAN_WHOLESALE_SUPPLIER_NAME="AzanWholeSale"
# Stock: on_sync = keep DB updated via product sync; push = (future) notify Azan on each local change; off = do nothing
AZAN_STOCK_STRATEGY="on_sync"

# --- Vercel / production: Project → Settings → Environment Variables ---
# Copy DATABASE_URL, NEXTAUTH_*, AZAN_WHOLESALE_* (use LIVE base + LIVE App Id/Secret for production).
# Preview/staging: point AZAN_WHOLESALE_BASE_URL to https://staging.azanwholesale.com and use sandbox keys.
# After deploy: prisma migrate deploy; set AZAN_WHOLESALE_FORWARD_ORDERS=true when order forwarding is tested.

# ============================================
# CRON (Vercel + local scripts) — also used for Facebook auto-post
# ============================================
# Secret for GET /api/cron/* (Authorization: Bearer <CRON_SECRET>)
# Vercel Cron can send this when CRON_SECRET is set in the project.
CRON_SECRET="use-openssl-rand-hex-32"

# ============================================
# FACEBOOK PAGE — automated marketing (Graph API)
# ============================================
# Create a long-lived Page access token with pages_manage_posts, pages_read_engagement.
# Page ID: Page → About → Page ID, or from Graph API /me/accounts
FACEBOOK_PAGE_ID=""
# Page access token (not a user token). Alternative name also supported: FB_PAGE_ACCESS_TOKEN
FACEBOOK_PAGE_ACCESS_TOKEN=""
# Optional: default v21.0
# FACEBOOK_GRAPH_API_VERSION="v21.0"

# Model for Banglish post copy (default: gpt-4o; use gpt-4o-mini to save cost)
# OPENAI_FACEBOOK_MODEL="gpt-4o"

# Endpoint: GET /api/cron/facebook-marketing?mode=newest|random&dryRun=1
# Vercel: schedule in vercel.json (default 03:00 UTC daily — adjust in dashboard if needed)
# Local: npm run cron:facebook  |  npx tsx scripts/cron-facebook-marketing.ts random --dry-run
